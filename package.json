{
  "name": "minamoscore",
  "version": "1.0.0",
  "description": "ブラウザ完結のピアノ採譜ツール。音声から楽譜（MusicXML/PDF）とMIDIを生成する。",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build/build.mjs",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "test": "node test/extract_test.mjs && node test/quantize_test.mjs && node test/deframe_test.mjs",
    "test:engine": "node test/engine_test.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"build/**/*.mjs\" \"test/**/*.mjs\" \"dist/**/*.js\" sw.js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "onnxruntime-node": "^1.20.0",
    "prettier": "3.6.2",
    "typescript": "^5.6.0"
  }
}
